
# --- Dependensi (Dependencies) ---
# Mengabaikan folder instalasi package di root, backend, dan frontend
node_modules/
backend/node_modules/
backend/package-lock.json
frontend/node_modules/

# --- Hasil Build & Output (Build Outputs) ---
# Mengabaikan hasil kompilasi production dari React Vite di folder frontend
frontend/dist/
frontend/dist-ssr/

# --- Log Aplikasi (Logs) ---
# Mengabaikan file log yang dihasilkan oleh Node.js backend atau frontend
*.log
backend/*.log
frontend/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- File Kredensial & Lingkungan (Environment Variables) ---
# SANGAT PENTING: Mengabaikan semua file .env di backend maupun frontend agar tidak bocor ke GitHub
.env
.env.local
*.env
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
auth.json
kredensial.json

# --- File Sistem Operasi & IDE (OS & Editor Files) ---
# Mengabaikan konfigurasi lokal editor VS Code atau berkas sampah OS di semua tingkat folder
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.sw?

# --- Diagnostik & Coverage ---
# Mengabaikan laporan testing otomatis jika ada
coverage/
backend/coverage/
frontend/coverage/
.eslintcache